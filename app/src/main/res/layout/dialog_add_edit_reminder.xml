<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- TÍTULO -->
        <EditText
            android:id="@+id/edtReminderTitle"
            android:hint="Título"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- DESCRIPCIÓN -->
        <EditText
            android:id="@+id/edtReminderDescription"
            android:hint="Descripción"
            android:layout_marginTop="10dp"
            android:minLines="3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- FECHA -->
        <EditText
            android:id="@+id/edtReminderDate"
            android:hint="Fecha"
            android:focusable="false"
            android:clickable="true"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- HORA -->
        <EditText
            android:id="@+id/edtReminderTime"
            android:hint="Hora"
            android:focusable="false"
            android:clickable="true"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- SPINNER TIPO -->
        <Spinner
            android:id="@+id/spinnerType"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- SPINNER MOVIMIENTO -->
        <Spinner
            android:id="@+id/spinnerMovement"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- SPINNER GOALS -->
        <Spinner
            android:id="@+id/spinnerLinkedGoal"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- SPINNER BUDGETS -->
        <Spinner
            android:id="@+id/spinnerLinkedBudget"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- USUARIOS VINCULADOS -->
        <LinearLayout
            android:id="@+id/usersContainer"
            android:orientation="vertical"
            android:layout_marginTop="15dp"
            android:background="@color/gray_light"
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Usuarios vinculados"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:id="@+id/layoutUsers"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- BOTÓN TOGGLE USUARIOS -->
        <Button
            android:id="@+id/btnToggleUsers"
            android:text="Mostrar/Ocultar usuarios"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- BOTONES GUARDAR / CANCELAR -->
        <Button
            android:id="@+id/btnSaveReminder"
            android:text="Guardar"
            android:backgroundTint="@color/green_dark"
            android:textColor="@android:color/white"
            android:layout_marginTop="15dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnCancelReminder"
            android:text="Cancelar"
            android:backgroundTint="@android:color/darker_gray"
            android:textColor="@android:color/white"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</ScrollView>
