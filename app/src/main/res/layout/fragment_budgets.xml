<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/budget_fragment_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Contenedor principal para scroll -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- HEADER -->
            <TextView
                android:id="@+id/tvBudgetTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Presupuestos"
                android:textColor="@color/green_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_wallet"
                android:drawablePadding="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btnAddBudget"
                app:layout_constraintHorizontal_bias="0" />

            <Button
                android:id="@+id/btnAddBudget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nuevo presupuesto"
                android:backgroundTint="@color/green_primary"
                android:textColor="@color/white"
                android:drawableStart="@drawable/ic_add_circle"
                android:drawablePadding="4dp"
                app:layout_constraintTop_toTopOf="@id/tvBudgetTitle"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- FILTROS -->
            <EditText
                android:id="@+id/etCategoryFilter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="Categoría"
                android:inputType="text"
                android:padding="8dp"
                android:background="@drawable/edit_text_background"
                app:layout_constraintTop_toBottomOf="@id/tvBudgetTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/spinnerStatusFilter"
                app:layout_constraintWidth_percent="0.45"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="8dp"/>

            <Spinner
                android:id="@+id/spinnerStatusFilter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:entries="@array/budget_status_options"
                app:layout_constraintTop_toBottomOf="@id/tvBudgetTitle"
                app:layout_constraintStart_toEndOf="@id/etCategoryFilter"
                app:layout_constraintEnd_toStartOf="@+id/btnApplyFilter"
                app:layout_constraintWidth_percent="0.25"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="12dp"/>

            <Button
                android:id="@+id/btnApplyFilter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filtrar"
                android:drawableStart="@drawable/ic_filter"
                android:drawablePadding="4dp"
                android:backgroundTint="@color/blueAccent"
                android:textColor="@color/white"
                app:layout_constraintTop_toBottomOf="@id/tvBudgetTitle"
                app:layout_constraintEnd_toStartOf="@+id/btnClearFilter"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnClearFilter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Limpiar"
                android:drawableStart="@drawable/ic_clear"
                android:drawablePadding="4dp"
                android:backgroundTint="@color/gray_dark"
                android:textColor="@color/white"
                app:layout_constraintTop_toBottomOf="@id/tvBudgetTitle"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="12dp"/>

            <!-- RECYCLER VIEW -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBudgets"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/etCategoryFilter"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:clipToPadding="false"/>

            <!-- VISTA VACÍA -->
            <TextView
                android:id="@+id/tvNoBudgets"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="No hay presupuestos creados todavía."
                android:gravity="center"
                android:textColor="@color/gray_dark"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/rvBudgets"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
