<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/movements_fragment_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <!-- 🟦 TÍTULO -->
            <TextView
                android:id="@+id/tvTitleMovements"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Movimientos"
                android:textColor="@color/green_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_movement"
                android:drawablePadding="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btnAddMovement"
                android:layout_marginBottom="8dp"/>

            <!-- ➕ BOTÓN AÑADIR -->
            <Button
                android:id="@+id/btnAddMovement"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nuevo"
                android:textAllCaps="false"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:backgroundTint="@color/green_primary"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_add_circle"
                android:drawablePadding="6dp"
                android:elevation="4dp"
                app:layout_constraintTop_toTopOf="@id/tvTitleMovements"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- 🧭 FILTROS -->
            <LinearLayout
                android:id="@+id/filter_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/card_background"
                android:elevation="3dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/tvTitleMovements"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Primera fila: categoría + tipo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/etCategoryFilter"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="Categoría"
                        android:inputType="text"
                        android:padding="12dp"
                        android:background="@drawable/edit_text_background"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:layout_marginEnd="8dp" />

                    <Spinner
                        android:id="@+id/spinnerTypeFilter"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:entries="@array/movement_type_filter"
                        android:padding="10dp"
                        android:background="@drawable/spinner_background"
                        android:textAlignment="center" />
                </LinearLayout>

                <!-- ⭐ FILTRO DE FECHA EXACTA -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/etDateFilter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Fecha"
                        android:focusable="false"
                        android:clickable="true"
                        android:padding="12dp"
                        android:background="@drawable/edit_text_background"
                        android:drawableStart="@drawable/ic_calendar"
                        android:drawablePadding="8dp"
                        android:textSize="16sp"/>
                </LinearLayout>

                <!-- Botones -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end">

                    <Button
                        android:id="@+id/btnApplyFilter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Filtrar"
                        android:textAllCaps="false"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/blueAccent"
                        android:drawableStart="@drawable/ic_filter"
                        android:drawablePadding="6dp"
                        android:layout_marginEnd="8dp"
                        android:elevation="3dp"/>

                    <Button
                        android:id="@+id/btnClearFilter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Limpiar"
                        android:textAllCaps="false"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/gray_dark"
                        android:drawableStart="@drawable/ic_clear"
                        android:drawablePadding="6dp"
                        android:elevation="3dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- 📋 LISTA DE MOVIMIENTOS -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewMovements"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                android:clipToPadding="false"
                android:paddingBottom="80dp"
                app:layout_constraintTop_toBottomOf="@id/filter_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- ⚠️ VISTA VACÍA -->
            <TextView
                android:id="@+id/tvEmptyState"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="No hay movimientos todavía."
                android:gravity="center"
                android:textColor="@color/gray_dark"
                android:textSize="16sp"
                android:padding="24dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/recyclerViewMovements"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
