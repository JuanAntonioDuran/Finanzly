<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="0dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_light">

    <!-- ALERTA DE PENDIENTES -->
    <LinearLayout
        android:id="@+id/alertPendingContainer"
        android:visibility="gone"
        android:padding="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/red_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <ImageView
            android:src="@drawable/ic_warning"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="8dp"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/txtPendingAlert"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:text="Tienes X recordatorios pendientes."
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtPendingCount"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginStart="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- ENCABEZADO + BOTÓN NUEVO -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <TextView
            android:text="Recordatorios"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/green_success"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnAddReminder"
            android:text="Nuevo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/blue_primary"
            android:textColor="@color/white"/>
    </LinearLayout>

    <!-- FILTROS -->
    <LinearLayout
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="4dp"
        android:layout_marginBottom="12dp">

        <EditText
            android:id="@+id/edtFilterSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Buscar por título o descripción"
            android:padding="8dp"/>

        <Spinner
            android:id="@+id/spinnerFilterType"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Spinner
            android:id="@+id/spinnerFilterStatus"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnClearFilters"
            android:layout_marginTop="10dp"
            android:text="Limpiar"
            android:backgroundTint="@color/gray_dark"
            android:textColor="@color/white"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnApplyFilters"
            android:layout_marginTop="10dp"
            android:text="Filtrar"
            android:backgroundTint="@color/blue_primary"
            android:textColor="@color/white"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerReminders"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

</LinearLayout>
