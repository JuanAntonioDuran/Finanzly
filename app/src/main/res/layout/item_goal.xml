<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:cardUseCompatPadding="true"
    android:padding="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/tvGoalTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Título de la meta"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/gray_dark"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvGoalStatus"
            android:layout_marginEnd="8dp"
            android:layout_marginStart="8dp"/>

        <!-- BADGE ESTADO -->
        <TextView
            android:id="@+id/tvGoalStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Activo"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_status_badge_green"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintTop_toTopOf="@id/tvGoalTitle"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- META -->
        <TextView
            android:id="@+id/tvGoalTarget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Meta: €0"
            android:textSize="15sp"
            android:textColor="@color/gray_dark"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvGoalTitle"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="8dp"/>

        <!-- PROGRESO -->
        <TextView
            android:id="@+id/tvGoalCurrent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Progreso: €0"
            android:textSize="15sp"
            android:textColor="@color/gray_dark"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvGoalTarget"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="8dp"/>

        <TextView
            android:id="@+id/tvGoalDeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha límite: --"
            android:textSize="15sp"
            android:textColor="@color/gray_dark"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvGoalCurrent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginEnd="10dp"
            android:layout_marginStart="8dp"/>

        <!-- BARRA DE PROGRESO -->
        <ProgressBar
            android:id="@+id/progressBarGoal"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="10dp"
            android:layout_marginTop="14dp"
            android:progress="0"
            android:progressTint="@color/green_primary"
            android:backgroundTint="@color/gray_light"
            app:layout_constraintTop_toBottomOf="@id/tvGoalDeadline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- BOTONES -->
        <LinearLayout
            android:id="@+id/actionsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/progressBarGoal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">



            <Button
                android:id="@+id/btnGoalDelete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Eliminar"
                android:drawableLeft="@drawable/ic_cross"
                android:drawablePadding="6dp"
                android:textAllCaps="false"
                android:backgroundTint="@android:color/holo_red_dark"
                android:textColor="@android:color/white"
                android:drawableTint="@android:color/white"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnItemLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Salir"
                android:drawableLeft="@drawable/ic_exit"
                android:drawablePadding="6dp"
                android:textAllCaps="false"
                android:backgroundTint="@android:color/holo_orange_light"
                android:textColor="@android:color/white"
                android:drawableTint="@android:color/white"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp" />


            <Button
                android:id="@+id/btnItemReminder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Rec."
                android:drawableLeft="@drawable/ic_reminder"
                android:drawablePadding="6dp"
                android:textAllCaps="false"
                android:backgroundTint="@color/green_primary"
                android:textColor="@android:color/white"
                android:drawableTint="@android:color/white"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
