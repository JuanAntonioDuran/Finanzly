<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    card_view:cardCornerRadius="14dp"
    card_view:cardElevation="4dp"
    card_view:cardUseCompatPadding="true"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 🟢 INFORMACIÓN -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvInvitationTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usuario te invitó"
                android:textColor="@color/green_primary"
                android:textStyle="bold"
                android:textSize="16sp"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvResourceType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Presupuesto / Objetivo"
                android:textColor="@color/gray_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mensaje opcional"
                android:textColor="#666666"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:maxLines="2"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2025-11-30"
                android:textColor="#999999"
                android:textSize="12sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- 🔘 ACCIONES / ESTADO -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_marginStart="12dp">

            <!-- Estado -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pendiente"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/status_badge"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <!-- Aceptar -->
            <Button
                android:id="@+id/btnAccept"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Aceptar"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:backgroundTint="@color/green_success"
                android:textColor="@android:color/white"
                android:visibility="gone"
                android:layout_marginBottom="6dp"/>

            <!-- Rechazar -->
            <Button
                android:id="@+id/btnDecline"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Rechazar"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:backgroundTint="@color/red_error"
                android:textColor="@android:color/white"
                android:visibility="gone"
                android:layout_marginBottom="6dp"/>

            <!-- Cancelar -->
            <Button
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Cancelar"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:backgroundTint="@color/gray_dark"
                android:textColor="@android:color/white"
                android:visibility="gone"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
