<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="6dp"
    app:cardUseCompatPadding="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- DESCRIPCIÓN -->
        <TextView
            android:id="@+id/tvMovementDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Descripción"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/gray_dark"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvMovementAmount"
            app:layout_constraintHorizontal_bias="0" />

        <!-- IMPORTE -->
        <TextView
            android:id="@+id/tvMovementAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00 €"
            android:textStyle="bold"
            android:textSize="17sp"
            android:textColor="@color/green_success"
            app:layout_constraintTop_toTopOf="@id/tvMovementDescription"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- CATEGORÍA -->
        <TextView
            android:id="@+id/tvMovementCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Categoría"
            android:textColor="@color/gray_dark"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvMovementDescription"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- FECHA -->
        <TextView
            android:id="@+id/tvMovementDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha"
            android:textSize="13sp"
            android:textColor="@color/gray_dark"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvMovementCategory"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- USUARIO -->
        <TextView
            android:id="@+id/tvMovementUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Usuario"
            android:textSize="13sp"
            android:textColor="@color/gray_dark"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvMovementDate"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- BOTÓN EDITAR -->
        <ImageButton
            android:id="@+id/btnEdit"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@android:color/transparent"
            android:padding="6dp"
            android:contentDescription="Editar"
            android:src="@drawable/ic_edit"
            app:tint="@color/blue_primary"
            app:layout_constraintTop_toBottomOf="@id/tvMovementUser"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="10dp"/>

        <!-- BOTÓN BORRAR -->
        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@android:color/transparent"
            android:padding="6dp"
            android:contentDescription="Eliminar"
            android:src="@drawable/ic_cross"
            app:tint="@color/red_error"
            app:layout_constraintTop_toTopOf="@id/btnEdit"
            app:layout_constraintStart_toEndOf="@id/btnEdit"
            android:layout_marginStart="6dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
