<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:cardUseCompatPadding="true"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- DESCRIPCIÓN -->
        <TextView
            android:id="@+id/tvMovementDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Compra supermercado"
            android:textStyle="bold"
            android:textSize="17sp"
            android:textColor="@color/gray_dark"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvMovementAmount" />

        <!-- IMPORTE -->
        <TextView
            android:id="@+id/tvMovementAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-45.00 €"
            android:textStyle="bold"
            android:textSize="17sp"
            android:textColor="@color/red_error"
            app:layout_constraintTop_toTopOf="@id/tvMovementDescription"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- TIPO (INGRESO / GASTO) -->
        <TextView
            android:id="@+id/tvMovementType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GASTO"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="4dp"
            android:textColor="@color/white"
            android:background="@color/red_error"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvMovementDescription"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- CATEGORÍA -->
        <TextView
            android:id="@+id/tvMovementCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Comida"
            android:textColor="@color/gray_dark"
            android:textSize="14sp"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="@id/tvMovementType"
            app:layout_constraintStart_toEndOf="@id/tvMovementType" />

        <!-- FECHA -->
        <TextView
            android:id="@+id/tvMovementDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="16/03/2026"
            android:textSize="13sp"
            android:textColor="@color/gray_dark"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvMovementType"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- VINCULACIÓN -->
        <TextView
            android:id="@+id/tvMovementLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vinculado a Presupuesto"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/blue_primary"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvMovementDate"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>