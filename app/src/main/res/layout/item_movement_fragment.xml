<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:cardUseCompatPadding="true"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- DESCRIPCIÓN -->
        <TextView
            android:id="@+id/tvMovementDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Descripción"
            android:textStyle="bold"
            android:textSize="17sp"
            android:textColor="@color/gray_dark"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvMovementAmount"
            app:layout_constraintHorizontal_bias="0" />

        <!-- IMPORTE -->
        <TextView
            android:id="@+id/tvMovementAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00 €"
            android:textStyle="bold"
            android:textSize="17sp"
            android:textColor="@color/green_success"
            app:layout_constraintTop_toTopOf="@id/tvMovementDescription"
            app:layout_constraintEnd_toEndOf="parent" />


        <!-- CATEGORÍA -->
        <TextView
            android:id="@+id/tvMovementCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Categoría"
            android:textColor="@color/gray_dark"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvMovementDescription"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- FECHA -->
        <TextView
            android:id="@+id/tvMovementDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha"
            android:textSize="13sp"
            android:textColor="@color/gray_dark"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvMovementCategory"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
