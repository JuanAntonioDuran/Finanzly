<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:background="@color/white">

    <LinearLayout
        android:orientation="vertical"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Título -->
        <TextView
            android:id="@+id/txtReminderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Título del recordatorio"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="16sp" />

        <!-- Descripción -->
        <TextView
            android:id="@+id/txtReminderDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descripción del recordatorio"
            android:textColor="@color/gray_dark"
            android:textSize="14sp"
            android:layout_marginTop="2dp" />

        <!-- Fecha y Hora -->
        <TextView
            android:id="@+id/txtReminderDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha"
            android:textColor="@color/gray_dark"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/txtReminderTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hora"
            android:textColor="@color/gray_dark"
            android:textSize="13sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/txtSharedCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Compartido con X usuarios"
            android:textColor="@color/gray_dark"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:visibility="gone"/>

        <!-- Botones -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnEditReminder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editar"
                android:textAllCaps="false"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/blue_primary"
                android:textColor="@color/white"/>

            <Button
                android:id="@+id/btnDeleteReminder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Borrar"
                android:textAllCaps="false"
                android:backgroundTint="@color/red_error"
                android:textColor="@color/white"/>

            <Button
                android:id="@+id/btnCompleteReminder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Completar"
                android:textAllCaps="false"
                android:backgroundTint="@color/green_light"
                android:textColor="@color/white"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
